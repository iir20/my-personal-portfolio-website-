rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net (Rule 1)
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { 
      return request.resource.data; 
    }
    
    function existing() { 
      return resource.data; 
    }

    // ----------------------------------------------------
    // Portfolio Configuration Document Rule
    // ----------------------------------------------------
    match /portfolio/config {
      allow read: if true;
      allow write: if incoming().heroName is string && 
                      incoming().heroName.size() <= 100 &&
                      incoming().heroTitle is string && 
                      incoming().heroTitle.size() <= 200;
    }

    // ----------------------------------------------------
    // Projects Collection Matching Blueprint
    // ----------------------------------------------------
    match /projects/{projectId} {
      allow read: if true;
      allow write: if true; // Allows the admin CMS to perform CRUD out of the box
    }

    // ----------------------------------------------------
    // Contacts Message Signals Collection
    // ----------------------------------------------------
    match /contacts/{contactId} {
      // Allow any visitor to transmit messages, validate presence & sizes
      allow create: if incoming().sender is string && 
                       incoming().sender.size() <= 100 &&
                       incoming().email is string && 
                       incoming().email.size() <= 150 &&
                       incoming().message is string && 
                       incoming().message.size() <= 3000;
      
      // Permit Admin/management system to inspect and delete messages
      allow read, delete: if true;
    }

    // ----------------------------------------------------
    // Telemetry Analytics Data
    // ----------------------------------------------------
    match /analytics/{eventId} {
      allow create: if incoming().timestamp is string;
      allow read, write: if true;
    }

    // ----------------------------------------------------
    // IDS Security and Threat logs
    // ----------------------------------------------------
    match /security/{logId} {
      allow create: if incoming().timestamp is string;
      allow read, write: if true;
    }
    
    // ----------------------------------------------------
    // Snap Backup Images
    // ----------------------------------------------------
    match /backups/{backupId} {
      allow read, write: if true;
    }
  }
}
