{
  "entities": {
    "portfolioContent": {
      "title": "Portfolio Content",
      "description": "Dynamic homepage contents, systemic layouts coordinates, and system prompts of Ratul's AI.",
      "type": "object",
      "properties": {
        "heroName": { "type": "string" },
        "heroTitle": { "type": "string" },
        "heroBio": { "type": "string" },
        "skills": { "type": "array" },
        "socialLinks": { "type": "array" },
        "timeline": { "type": "array" },
        "systemPrompt": { "type": "string" },
        "themeColor": { "type": "string" },
        "animationsActive": { "type": "boolean" }
      },
      "required": ["heroName", "heroTitle"]
    },
    "projects": {
      "title": "Projects",
      "description": "Custom project models register containing repository metadata, tech credentials, and interactive indicators.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "year": { "type": "string" },
        "description": { "type": "string" },
        "languages": { "type": "array" },
        "github": { "type": "string" },
        "liveUrl": { "type": "string" },
        "featured": { "type": "boolean" },
        "order": { "type": "number" }
      },
      "required": ["id", "name", "description"]
    },
    "contactMessages": {
      "title": "Contact Messages",
      "description": "Transmitted cryptographic packet signals from incoming visitors and recruiters.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sender": { "type": "string" },
        "email": { "type": "string" },
        "frequency": { "type": "string" },
        "message": { "type": "string" },
        "packetSignature": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["sender", "email", "message"]
    },
    "analytics": {
      "title": "Analytics Data",
      "description": "Telemetry parameters recording visitor hits, system logs, active alerts and performance telemetry.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "visitorIp": { "type": "string" },
        "userAgent": { "type": "string" },
        "timestamp": { "type": "string" },
        "page": { "type": "string" },
        "eventType": { "type": "string" }
      },
      "required": ["timestamp", "page"]
    },
    "securityLogs": {
      "title": "Security Log",
      "description": "Hacker threat tracking database, defensive block logs, and system diagnostics metrics.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "message": { "type": "string" },
        "attackerIp": { "type": "string" },
        "severity": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["type", "message", "timestamp"]
    }
  },
  "firestore": {
    "/portfolio/config": {
      "schema": "portfolioContent",
      "description": "Synchronous repository deck and custom homepage layouts configurations document."
    },
    "/projects/{projectId}": {
      "schema": "projects",
      "description": "Active cybernetic project registries."
    },
    "/contacts/{contactId}": {
      "schema": "contactMessages",
      "description": "Incoming encrypted connection signals registers."
    },
    "/analytics/{eventId}": {
      "schema": "analytics",
      "description": "Live telemetry visitor streams collection."
    },
    "/security/{logId}": {
      "schema": "securityLogs",
      "description": "Defensive block records and real-time IDS event records."
    }
  }
}
